{
  "name": "teamart_pr",
  "version": "1.0.0",
  "private": true,
  "description": "Teamart — production ready ecommerce starter built with Next.js, React, Tailwind, Clerk, Sanity, and Stripe",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p $PORT",
    "preview": "next start --port 3001",
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@clerk/nextjs": "^7.0.1",
    "@sanity/client": "^7.16.0",
    "@tailwindcss/postcss": "^4.2.1",
    "autoprefixer": "^10.4.27",
    "framer-motion": "^12.35.0",
    "http-proxy": "^1.18.1",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn-ui": "^0.9.5",
    "stripe": "^20.4.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/line-clamp": "^0.4.0",
    "@types/react": "19.2.14",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.0.2",
    "husky": "^9.0.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "rimraf": "^5.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
